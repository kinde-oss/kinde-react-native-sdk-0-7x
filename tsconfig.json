{
    "compilerOptions": {
        "declaration": true,
        "target": "es5",
        "module": "commonjs",
        "strict": true,
        "emitDeclarationOnly": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "lib": ["es2016"],
        "types": ["react-native"],
        "resolveJsonModule": true,
        "baseUrl": ".",
        "paths": {
            "@kinde/js-utils": ["node_modules/@kinde/js-utils/dist/lib/main"]
        }
    },
    "include": ["src"],
    "exclude": ["dist", "node_modules", "**/__tests__/*", "**/test/*"]
}
